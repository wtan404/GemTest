{%- liquid
  assign social_accounts = 'Facebook, Twitter, Pinterest, Instagram, Snapchat, TikTok, Tumblr, YouTube, LinkedIn, Threads, WhatsApp, Discord, Twitch, Messenger, Email, Vimeo' | split: ', '
-%}
<div class="flex">
  {% for social in social_accounts %}
    {%- assign social_handle = social | handleize -%}
    {% capture social_link %}social_{{ social_handle }}_link{% endcapture %}
    {% if settings[social_link] != blank %}
      {% if settings.social_style == 'icons' %}
        <span class="mx-2 mt-2">
          <a
            class="fill-current"
            href="{% if social_handle == 'email' %}mailto:{% endif %}{{ settings[social_link] }}"
            target="_blank"
          >
            <span class="inline-block h-5 w-5" aria-hidden="true">
              {%- liquid
                case social_handle
                  when 'facebook'
                    render 'icon-facebook'
                  when 'twitter'
                    render 'icon-twitter'
                  when 'pinterest'
                    render 'icon-pinterest'
                  when 'instagram'
                    render 'icon-instagram'
                  when 'snapchat'
                    render 'icon-snapchat'
                  when 'email'
                    render 'icon-email'
                  when 'tumblr'
                    render 'icon-tumblr'
                  when 'youtube'
                    render 'icon-youtube'
                  when 'linkedin'
                    render 'icon-linkedin'
                  when 'tiktok'
                    render 'icon-tiktok'
                  when 'threads'
                    render 'icon-threads'
                  when 'whatsapp'
                    render 'icon-whatsapp'
                  when 'discord'
                    render 'icon-discord'
                  when 'twitch'
                    render 'icon-twitch'
                  when 'messenger'
                    render 'icon-messenger'
                  when 'vimeo'
                    render 'icon-vimeo'
                endcase
              -%}
            </span>
            <span class="visually-hidden">{{ social }}</span>
          </a>
        </span>
      {% else %}
        <li class="mx-2 mt-2">
          <a
            class="inline-block {{ link_class }} secondary-text-link"
            href="{% if social_handle == 'email' %}mailto:{% endif %}{{ settings[social_link] }}"
          >
            {{ social }}
          </a>
        </li>
      {% endif %}
    {% endif %}
  {% endfor %}
</div>
