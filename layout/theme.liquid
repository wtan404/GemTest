<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>


<!-- LAYOUTHUB-V2-HEADER --> 
{%- render 'layouthub-header' -%}
<!-- END LAYOUTHUB-V2-HEADER -->
{{ "layouthub-jquery.min.js" | asset_url | script_tag }}
{% comment  %}
 {% endcomment  %}
<!-- Start of Shoplift scripts -->
{% render 'shoplift' %}
<!-- End of Shoplift scripts -->

