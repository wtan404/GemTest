{%- liquid
  assign block_heading_level = 'h2'
  assign highlights = section.blocks | where: 'type', 'highlight'
  assign slideshow_on_mobile = section.settings.slideshow_on_mobile
  assign image_max_width = section.settings.max_width

  assign preload = false

  if section.index == 1
    assign preload = true
  endif

  assign loading = 'lazy'

  if section.index <= 3
    assign loading = 'eager'
  endif

  assign sizes = '(min-width: 990px) min(' | append: image_max_width | append: 'px, 50vw), 100vw'

  assign mobile_blocks = ''
  assign left_column_blocks = ''
  assign right_column_blocks = ''
-%}

{%- render 'shape-defs',
  shape: section.settings.image_shape,
  shape_id: section.id,
  blob_type: section.settings.blob_type
-%}

{%- capture image -%}
{%- if section.settings.image != blank -%}
  {%- render 'media-image',
    media: section.settings.image,
    shape_id: section.id,
    shape: section.settings.image_shape,
    crop: section.settings.crop,
    rotate: section.settings.rotate_image,
    is_card: false,
    container_id: section.id,
    disable_media_style: section.settings.disable_media_style,
    preload: preload,
    loading: loading,
    sizes: sizes
  -%}
{%- else -%}
  {%- render 'media-image-placeholder',
    shape_id: section.id,
    container_id: section.id,
    shape: section.settings.image_shape,
    crop: section.settings.crop,
    rotate: section.settings.rotate_image,
    is_card: section.settings.display_on_card,
    blob_type: section.settings.blob_type,
    disable_media_style: section.settings.disable_media_style
  -%}
{%- endif -%}
{%- endcapture -%}

{%- capture video -%}
  {%- if section.settings.video != blank -%}
    {%- render 'media-video',
      media: section.settings.video,
      mode: "autoplay",
      playback: section.settings.playback,
      shape_id: section.id,
      shape: section.settings.image_shape,
      crop: section.settings.crop,
      rotate: section.settings.rotate_image,
      is_card: section.settings.display_on_card,
      container_id: section.id,
      disable_media_style: section.settings.disable_media_style,
      preload: preload,
      loading: loading,
      sizes: sizes
    -%}
  {%- endif -%}
{%- endcapture -%}

{%- for block in highlights -%}
  {%- capture block_content -%}
    <div class="{% if section.settings.display_on_card %}card__surface{% endif %} p-5 text-center lg:flex lg:flex-1 lg:items-center lg:justify-center">
      <div class="w-full">
        {% if block.settings.title != '' %}
          <{{ block_heading_level }} class="font-heading heading-secondary break-words image-with-highlights__title">
            {{- block.settings.title -}}
          </{{ block_heading_level }}>
        {% endif %}
        {%- if block.settings.text != blank -%}
          <div class="inline-rte image-with-highlights__text {% if block.settings.title != '' %}mt-2.5{% endif %}">
            {{ block.settings.text }}
          </div>
        {%- endif -%}
        {% if block.settings.cta_link and block.settings.cta_text != blank %}
          <div class="relative z-10 mt-5">
            <a
              href="{{ block.settings.cta_link }}"
              class="push-btn inline-block"
            >
              <span class="push-btn__surface">
                {{- block.settings.cta_text -}}
              </span>
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  {%- endcapture -%}

  {%- capture mobile_block -%}
    <li
      class="{% if slideshow_on_mobile %}splide__slide w-full{% endif %} relative lg:col-span-3 {% if section.settings.display_on_card %}text-scheme-text card{% endif %}"
      {% if block.settings.override_section_color_scheme %}
        data-color-scheme="{{ block.settings.color_scheme }}"
      {% endif %}
      {{ block.shopify_attributes }}
    >
      {{ block_content }}
    </li>
  {%- endcapture -%}

  {%- capture desktop_block -%}
    <div
      class="{% if section.settings.display_on_card %}text-scheme-text card{% endif %} "
      {% if block.settings.override_section_color_scheme %}
        data-color-scheme="{{ block.settings.color_scheme }}"
      {% endif %}
      {{ block.shopify_attributes }}
    >
      {{ block_content }}
    </div>
  {%- endcapture -%}

  {%- liquid
    assign mod = forloop.index0 | modulo: 2
    if mod == 0
      assign left_column_blocks = left_column_blocks | append: desktop_block
    else
      assign right_column_blocks = right_column_blocks | append: desktop_block
    endif

    assign mobile_blocks = mobile_blocks | append: mobile_block
  -%}
{%- endfor -%}

<section
  class="relative bg-scheme-background text-scheme-text image-with-highlights {% if section.settings.use_gradient_background %}bg-scheme-gradient{% endif %} relative overflow-hidden"
  data-color-scheme="{{ section.settings.color_scheme }}"
  style="
    --image-max-width: {{ image_max_width }}px;
    --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
  "
>
  <div class="section-content relative z-10 {% if slideshow_on_mobile %}lg:px-section lg:max-w-site lg:mx-auto{% else %}px-section{% endif %}">
    {% if section.settings.title != '' %}
      {%- assign block_heading_level = 'h3' -%}
      <h2 class="image-with-highlights__headding inline-heading-rte font-heading heading-standard  heading-style break-words text-center {{ settings.heading_drop_shadow_style }}">
        {{ section.settings.title }}
      </h2>
    {% endif %}
    {% if section.settings.cta_link and section.settings.cta_text != blank %}
      <div class="relative text-center image-with-highlights__btn">
        <a
          href="{{ section.settings.cta_link }}"
          class="push-btn inline-block"
        >
          <span class="push-btn__surface">
            {{- section.settings.cta_text -}}
          </span>
        </a>
      </div>
    {% endif %}

    <div class="hidden grid-cols-4 gap-theme lg:grid image-with-highlights__inner  {% if section.settings.title != '' %}section-content-top-margin{%  endif %}">
      <!-- Left Column -->
      <div class="col-span-1 flex-col image-with-highlights__col {{ section.settings.block_alignment_on_desktop }} gap-theme">
        {{ left_column_blocks }}
      </div>

      <!-- Middle Column -->
      <div class="col-span-2 flex items-center justify-center">
        <div class="w-full {% if settings.media_shadow_direction contains 'top' %}pt-media-shadow{% else %}pb-media-shadow{% endif %} max-w-[var(--image-max-width)]">
          {%- if section.settings.video != blank  -%}
            {{- video -}}
          {%- else -%}
            {{ image }}
          {%- endif -%}
        </div>
      </div>

      <!-- Right Column -->
      <div class="col-span-1 flex-col image-with-highlights__col {{ section.settings.block_alignment_on_desktop }} gap-theme">
        {{ right_column_blocks }}
      </div>
    </div>

    <div class="lg:hidden">
      <div class="max-w-site {% if slideshow_on_mobile %}px-section{% endif %} lg:hidden {% if section.settings.title != '' %}section-content-top-margin{%  endif %} {% if settings.media_shadow_direction contains 'top' %}pt-media-shadow{% else %}pb-media-shadow{% endif %}">
        {%- if section.settings.video != blank  -%}
          {{- video -}}
        {%- else -%}
          {{ image }}
        {%- endif -%}
      </div>

      <div
        {% if slideshow_on_mobile %}
          id="slideshow-{{ section.id }}"
        {% endif %}
        class="mt-10 {% if slideshow_on_mobile %}splide{% endif %}"
      >
        <div class="{% if slideshow_on_mobile %}splide__track {% if section.settings.display_on_card %}{% if settings.card_shadow_direction contains 'top' %}pt-card-shadow{% else %}pb-card-shadow{% endif %}{% endif %}{% endif %}">
          <ul class="{% if slideshow_on_mobile %}splide__list{% endif %} {% if section.settings.title != '' %}section-content-top-margin{% endif %} {% if slideshow_on_mobile %}lg:grid lg:gap-10{% else %}grid grid-cols-1 gap-10{% endif %} lg:grid-cols-12 ">
            {{ mobile_blocks }}
          </ul>
        </div>
        {%- if slideshow_on_mobile -%}
          <script class="slideshow-options" type="application/json">
            {
              "mediaQuery": "min",
              "arrows": false,
              "pagination": true,
              "rewind": true,
              "autoWidth": true,
              "gap": "12px",
              "focus": {{ section.settings.slideshow_focus | json }},
              "type": "{% if section.settings.slideshow_focus == 'left' %}slide{% else %}loop{% endif %}",
              "autoScroll": {
                "autoStart": false,
                "speed": {{ section.settings.autoscroll_mode | plus: 0 | json }}
              },
              "padding": {
                "left": "1.25rem",
                "right": "1.25rem"
              },
              "breakpoints": {
                "990": {
                  "destroy": "true"
                }
              }
            }
          </script>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- liquid
    for block in section.blocks
      case block.type
        when 'background_shape'
          render 'block-background-shape', block: block
        when 'background_pattern'
          render 'block-background-pattern', block: block, scheme: section.settings.color_scheme
      endcase
    endfor
  -%}
</section>

{%- liquid
  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider
  endfor
-%}

