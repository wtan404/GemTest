{%- comment -%}
  This is a required section for the Shopify Theme Store.
  It is available in the "Featured Collection" section in the theme editor.

  Theme Store required settings
  - Collection

  Theme Store optional settings
  - Heading: title of the featured collection section
{%- endcomment -%}
{%- style -%}
  #facets-form details[open] > summary svg {
    transform: rotate(180deg);
  }
{%- endstyle -%}

{%- liquid
  assign mobile_grid_cols = section.settings.products_per_row_mobile
  assign shape_id = section.id
  case section.settings.products_per_row_desktop
    when 2
      assign desktop_grid_cols = 'lg:grid-cols-2'
    when 3
      assign desktop_grid_cols = 'lg:grid-cols-3'
    when 4
      assign desktop_grid_cols = 'lg:grid-cols-4'
    when 5
      assign desktop_grid_cols = 'lg:grid-cols-5'
  endcase
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign collection_banner_block = section.blocks | where: 'type', 'collection_banner'
  for block in collection_banner_block
    assign collection_banner = block
  endfor

  assign eager_loading_limit = mobile_grid_cols | plus: 0

  if section.settings.display_on_card
    assign desktop_sizes = 'calc((100vw / ' | append: section.settings.products_per_row_desktop | append: ') - 2.5rem)'

    if section.settings.products_per_row_mobile == '2'
      assign mobile_sizes = 'calc((100vw / ' | append: section.settings.products_per_row_mobile | append: ') - 1.25rem)'
    else
      assign mobile_sizes = 'calc((100vw / ' | append: section.settings.products_per_row_mobile | append: ') - 2.5rem)'
    endif
  else
    assign desktop_sizes = 'calc(100vw / ' | append: section.settings.products_per_row_desktop | append: ')'
    assign mobile_sizes = 'calc(100vw / ' | append: section.settings.products_per_row_mobile | append: ')'
  endif

  assign sizes = '(min-width: 990px) ' | append: desktop_sizes | append: ', ' | append: mobile_sizes
-%}

{%- render 'collection-shape-defs',
  shape: settings.product_tile_media_shape,
  section_id: section.id,
  item_count: section.settings.no_products
-%}

{%- paginate collection.products by section.settings.no_products -%}
  <data-island
    class="relative grid bg-scheme-background text-scheme-text  {% if section.settings.use_gradient_background %}bg-scheme-gradient{% endif %} {% if collection.image != blank and collection_banner.settings.show_collection_image and collection_banner.settings.collection_image_style == 'full' %}full-bleed-section{% endif %}"
    role="banner"
    data-color-scheme="{{ section.settings.color_scheme }}"
    x-data="Filterable"
  >
    {%- if section.settings.enable_filtering -%}
      <template x-teleport="#left-drawer-slot">
        <div x-show="$store.modals.leftDrawer.contents === 'filters'" class="flex h-full flex-col p-5">
          <form id="facets-form" @submit.prevent="filterFormSubmit($event, 'filters')">
            <div class="flex items-center justify-between border-b-section border-scheme-text/10 pb-5">
              <h2 class="font-heading text-scale-n1">{{ 'facets.filters.title_tags' | t }}</h2>
              <a href="{{ collection.url }}" class="text-sm theme-underline" @click.prevent="clearAllFilters($event)">
                {{ 'facets.filters.clear' | t }}
              </a>
            </div>

            <div class="flex-1 overflow-y-auto py-5">
              {%- for filter in collection.filters -%}
                <details class="border-b-section border-scheme-text/10 py-4" {% if section.settings.expand_filters %}open{% endif %}>
                  <summary class="flex cursor-pointer items-center justify-between">
                    
                    <span class="font-bold">
                      {{ filter.label | escape }}     
                    </span>
                    <span class="size-6">
                    {% render 'icon-chevron-down', class: 'size-4 flex-shrink-0 transition-transform' %}
                    </span>
                  </summary>

                  <div class="pt-4">
                    {%- case filter.type -%}
                      {%- when 'list' or 'boolean' -%}
                        <ul class="space-y-2">
                          {%- for value in filter.values -%}
                            <li>
                              <label class="flex cursor-pointer items-center text-sm">
                                <input
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value }}"
                                  id="filter-{{ filter.label | handleize }}-{{ forloop.index }}"
                                  class="peer sr-only"
                                  {% if value.active %}
                                    checked
                                  {% endif %}
                                >
                                <span class="custom-checkbox__input relative mr-2 h-4 w-4 min-w-[1rem] border-current before:absolute before:left-1/2 before:top-1/2 before:h-1/2 before:w-1/2 before:-translate-x-1/2 before:-translate-y-1/2 before:opacity-0 before:content-empty peer-checked:border-opacity-100 peer-checked:bg-scheme-text peer-checked:before:opacity-100 before:bg-scheme-text-contrast"></span>
                                <span>{{ value.label | escape }}</span>
                                {%- if section.settings.show_filter_count -%}
                                  <span class="ml-auto text-xs opacity-70">({{ value.count }})</span>
                                {%- endif -%}
                              </label>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- when 'price_range' -%}
                        <div class="flex items-center gap-2">
                          <div class="relative flex-1">
                            <span class="absolute left-2 top-1/2 -translate-y-1/2 text-sm opacity-50">{{ cart.currency.symbol }}</span>
                            <input
                              name="{{ filter.min_value.param_name }}"
                              id="filter-price-gte"
                              type="number"
                              placeholder="{{ 'facets.filters.from' | t }}"
                              class="input w-full py-1 pl-6 pr-2 text-sm"
                              value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                            >
                          </div>
                          <span>-</span>
                          <div class="relative flex-1">
                            <span class="absolute left-2 top-1/2 -translate-y-1/2 text-sm opacity-50">{{ cart.currency.symbol }}</span>
                            <input
                              name="{{ filter.max_value.param_name }}"
                              id="filter-price-lte"
                              type="number"
                              placeholder="{{ 'facets.filters.to' | t }}"
                              class="input w-full py-1 pl-6 pr-2 text-sm"
                              value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                            >
                          </div>
                        </div>
                    {%- endcase -%}
                  </div>
                </details>
              {%- endfor -%}
            </div>

            <div class="mt-auto border-t-section border-scheme-text/10 pt-5">
              <button type="submit" class="push-btn w-full">
                <span class="push-btn__surface">
                  {{ 'facets.filters.apply' | t }}
                </span>
              </button>
            </div>
          </form>
          </div>
      </template>
    {%- endif -%}
    {%- liquid
      assign loading = 'lazy'
      if section.index <= 3
        assign loading = 'eager'
      endif
    -%}

    {%- if collection_banner_block.size > 0 -%}
      {%- render 'collection-banner',
        show_collection_image: collection_banner.settings.show_collection_image,
        collection_image_style: collection_banner.settings.collection_image_style,
        crop: collection_banner.settings.crop,
        display_on_card: collection_banner.settings.display_on_card,
        show_collection_title: collection_banner.settings.show_collection_title,
        show_collection_description: collection_banner.settings.show_collection_description,
        linklist: collection_banner.settings.linklist,
        loading: loading
      -%}
    {%- endif -%}

    <div
      class="section-content relative z-10 mx-auto w-full max-w-site overflow-hidden px-section  pb-section-vertical-spacing pt-half-section-vertical-spacing"
      id="facets-filterable"
    >
      {%- if section.settings.enable_filtering
        or section.settings.enable_sorting
      -%}
        <div class="flex items-center justify-end gap-5 pb-5 lg:pb-10">
          {%- if section.settings.enable_filtering -%}
            {%- liquid
              assign total_active_values = 0
              for filter in collection.filters
                assign total_active_values = total_active_values | plus: filter.active_values.size
                if filter.type == 'price_range'
                  if filter.max_value.value or filter.min_value.value
                    assign total_active_values = total_active_values | plus: 1
                  endif
                endif
              endfor
            -%}
            <button
              role="button"
              class="push-btn w-1/2 lg:w-auto"
              @click="$store.modals.open('filters')"
            >
              <span class="push-btn__surface push-btn__surface--secondary pointer-events-none w-full lg:w-auto">
                {{- 'facets.filters.title_tags' | t }}
                {% if total_active_values > 0 -%}
                  ({{ total_active_values }})
                {%- endif -%}
              </span>
            </button>
            <div class="hidden" id="facets-results-count">
              {%- if collection.products_count == 1 -%}
                {{
                  'collections.general.items_with_count.one'
                  | t: count: collection.products_count
                }}
              {%- else -%}
                {{
                  'collections.general.items_with_count.other'
                  | t: count: collection.products_count
                }}
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if section.settings.enable_sorting -%}
           {%- render 'sort', results: collection, sort_by: sort_by -%}
          {%- endif -%}
        </div>
      {%- endif -%}

      <div
        class="{% if settings.product_tiles_scatter %}py-4{% endif %}"
        id="facets-results"
      >
        {%- if collection.products.size == 0 -%}
          <p class="text-center">{{ 'collections.general.no_matches' | t }}</p>
        {%- else -%}
          {% assign banner_blocks = section.blocks | where: "type", "banner_item" %}
          <ul class="grid gap-theme {% if mobile_grid_cols == '2' %}grid-cols-2{% else %}grid-cols-1{% endif %} {{ desktop_grid_cols }}">
            {% assign collectionMeta = collection.metafields.custom %}
            
            {% if collectionMeta.grid_ft_slot_link.value.url %}
              {% assign gridFeaturedLink = collectionMeta.grid_ft_slot_link.value %}
            <li>
              <a class="flex-col items-center w-full h-full md:w-auto" style="justify-content:space-between" href="{{ gridFeaturedLink.url }}" alt="{{ gridFeaturedLink.text }}" >
                <div>
                    <img src="{{ collectionMeta.grid_ft_slot_image | img_url: 'original' }}" />
                    <p>{{ collectionMeta.grid_ft_slot_Text }}</p>
                </div>
                <button type="button"
                  class="border rounded-button font-bold btn-hover" style="margin-bottom:20px;padding:12px;">
                  {{ collectionMeta.grid_ft_slot_cta }}
                </button>
              </a>
            </li>
            {% else %}
              {% if section.settings.gridFeaturedSlot %}
            <li>
              <a class="flex-col items-center w-full h-full md:w-auto" style="justify-content:space-between" href="{{ section.settings.gridFeaturedSlotLink }}">
                <div >
                    <img src="{{ section.settings.gridFeaturedSlotImage | img_url: 'original' }}" />
                    <h6 class="font-heading text-2xl font-bold mb-2">{{ section.settings.gridFeaturedSlotHeading }}</h6>
                    <p>{{ section.settings.gridFeaturedSlotSubText }}</p>
                </div>
                <button type="button"
                    class="border rounded-button font-bold btn-hover" style="margin-bottom:20px;padding:12px;">
                    {{ section.settings.gridFeaturedSlotButtonText }}
                </button>
              </a>
            </li>

              {% endif %}
            {% endif %}


            {%- for product in collection.products -%}
              {% assign current_index = forloop.index %}
              {%- for block in banner_blocks -%}
                {% assign banner_position = block.settings.position | plus: 0 %}
                  {% if block.settings.banner_image != blank and current_index == banner_position %}
                  <li class="banner-item">
                      <img src="{{ block.settings.banner_image | img_url: 'large' }}" alt="Banner Image" class="w-full h-full object-cover rounded-card" />
                  </li>
                {% endif %}
              {%- endfor -%}
              <li class="">
                {%- liquid
                  if settings.product_tiles_scatter
                    capture class
                      case section.settings.products_per_row_mobile
                        when '2'
                          cycle 'max-lg:-translate-y-4 ', 'max-lg:translate-y-4 '
                      endcase
                      case section.settings.products_per_row_desktop
                        when 3
                          cycle 'lg:translate-y-4 ', 'lg:-translate-y-4 ', 'lg:translate-y-4 '
                        when 2, 4
                          cycle 'lg:-translate-y-4 ', 'lg:translate-y-4 '
                        when 5
                          cycle 'lg:translate-y-4 ', 'lg:-translate-y-4 ', 'lg:translate-y-4 ', 'lg:-translate-y-4 ', 'lg:translate-y-4 '
                      endcase
                    endcapture
                  endif
                  capture odd_even
                    cycle 'odd', 'even'
                  endcapture

                  if settings.product_tile_media_shape == 'blob'
                    assign shape_id = section.id | append: '-' | append: forloop.index0
                  endif

                  assign product_tile_loading = 'lazy'
                  if section.index <= 3 and forloop.index <= eager_loading_limit
                    assign product_tile_loading = 'eager'
                  endif
                -%}
                {%- render 'product-tile',
                  product: product,
                  shape_id: shape_id,
                  display_on_card: section.settings.display_on_card,
                  class: class,
                  odd_even: odd_even,
                  index: forloop.index0,
                  products_per_row_mobile: section.settings.products_per_row_mobile,
                  enable_quick_buy: section.settings.enable_quick_buy,
                  loading: product_tile_loading,
                  sizes: sizes
                -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- liquid
        if paginate.pages > 1
          render 'pagination', paginate: paginate, anchor: ''
        endif
      -%}
    </div>

    {%- liquid
      for block in section.blocks
        case block.type
          when 'background_shape'
            render 'block-background-shape', block: block
          when 'background_pattern'
            render 'block-background-pattern', block: block, scheme: section.settings.color_scheme
          when 'shape_divider'
            render 'block-shape-divider', block: block
        endcase
      endfor
    -%}
  </data-island>
{%- endpaginate -%}

{%- if section.settings.enable_collection_bundle and section.settings.bundle_product != blank -%}
  <div class="collection-grid__bundle relative bg-scheme-background text-scheme-text {% if section.settings.use_gradient_background %}bg-scheme-gradient{% endif %}" data-color-scheme="{{ section.settings.color_scheme }}">
    <div class="collection-grid__bundle-inner section-content relative z-10 mx-auto overflow-hidden px-container py-section-vertical-spacing">
      <p class="collection-grid__bundle-text text-lg lg:text-xl text-center mb-2">
        {{ section.settings.bundle_text }}
      </p>
      <div class="collection-grid__bundle-product">
        {%- render 'product-tile',
          product: section.settings.bundle_product,
          class: class,
          odd_even: odd_even,
          enable_quick_buy: section.settings.enable_quick_buy,
          loading: product_tile_loading,
          sizes: sizes
        -%}
      </div>
    </div>
  </div>
{%- endif -%}

{%- assign stickers = section.blocks | where: 'type', 'sticker' -%}
{%- liquid
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
-%}

{% schema %}
{
  "name": "t:sections.product_grid.name",
  "settings": [
    {
      "type": "range",
      "id": "no_products",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 16,
      "label": "t:sections.product_grid.settings.no_products.label"
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "t:common.settings.products_per_row_mobile.label",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "t:common.options.1.label"
        },
        {
          "value": "2",
          "label": "t:common.options.2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "display_on_card",
      "label": "t:common.settings.display_on_card.label"
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "t:common.settings.products_per_row_desktop.label",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "enable_quick_buy",
      "label": "t:common.settings.enable_quick_buy.label"
    },
    {
      "type": "header",
      "content": "Featured Slot Settings"
    },
    {
      "type": "checkbox",
      "id": "gridFeaturedSlot",
      "label": "Enable Featured Slot"
    },
    {
      "type": "image_picker",
      "id": "gridFeaturedSlotImage",
      "label": "Featured Slot Background Image"
    },
    {
      "type": "text",
      "id": "gridFeaturedSlotHeading",
      "label": "Featured Slot Heading"
    },
    {
      "type": "text",
      "id": "gridFeaturedSlotSubText",
      "label": "Featured Slot SubText"
    },
    {
      "type": "url",
      "id": "gridFeaturedSlotLink",
      "label": "Featured Slot - Link Target",
    },
    {
      "type": "text",
      "id": "gridFeaturedSlotButtonText",
      "label": "Featured Button Text"
    },
    {
      "type": "header",
      "content": "t:sections.product_grid.settings.header_bundle_product.content"
    },
    {
      "type": "checkbox",
      "id": "enable_collection_bundle",
      "label": "t:sections.product_grid.settings.enable_collection_bundle.label",
      "default": false
    },
    {
      "type": "product",
      "id": "bundle_product",
      "label": "t:sections.product_grid.settings.bundle_product.label"
    },
    {
      "type": "text",
      "id": "bundle_text",
      "label": "t:sections.product_grid.settings.bundle_text.label"
    },
    {
      "type": "header",
      "content": "t:common.settings.header_filtering_and_sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "t:common.settings.enable_filtering.label",
      "info": "t:common.settings.enable_filtering.info"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "t:common.settings.enable_sorting.label"
    },
    {
      "type": "checkbox",
      "id": "expand_filters",
      "label": "t:common.settings.expand_filters.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filter_count",
      "label": "t:common.settings.show_filter_count.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_color_swatch_filters",
      "label": "t:common.settings.enable_color_swatch_filters.label",
      "info": "t:common.settings.enable_color_swatch_filters.info"
    },
    {
      "type": "header",
      "content": "t:common.settings.header_color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme1",
      "label": "t:common.settings.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "use_gradient_background",
      "label": "t:common.settings.use_gradient_background.label"
    }
  ],
  "blocks": [
    {
      "type": "collection_banner",
      "name": "t:sections.product_grid.blocks.collection_banner.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.product_grid.blocks.collection_banner.settings.paragraph_use_this_block"
        },
        {
          "type": "checkbox",
          "id": "display_on_card",
          "label": "t:common.settings.display_on_card.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_collection_title",
          "label": "t:common.settings.show_collection_title.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_collection_description",
          "label": "t:common.settings.show_collection_description.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_collection_image",
          "label": "t:common.settings.show_collection_image.label"
        },
        {
          "type": "select",
          "id": "collection_image_style",
          "label": "t:sections.product_grid.blocks.collection_banner.settings.collection_image_style.label",
          "default": "full",
          "options": [
            {
              "value": "inset",
              "label": "t:common.options.inset.label"
            },
            {
              "value": "full",
              "label": "t:common.options.full_width.label"
            }
          ]
        },
        {
          "type": "select",
          "id": "crop",
          "label": "t:common.settings.crop.label",
          "options": [
            {
              "value": "",
              "label": "t:common.options.no_crop.label"
            },
            {
              "value": "aspect-w-1 aspect-h-1",
              "label": "t:common.options.square.label"
            },
            {
              "value": "aspect-w-3 aspect-h-4",
              "label": "t:common.options.portrait.label"
            },
            {
              "value": "aspect-w-4 aspect-h-3",
              "label": "t:common.options.landscape.label"
            },
            {
              "value": "aspect-w-10 aspect-h-4",
              "label": "t:common.options.super_wide.label"
            },
            {
              "value": "aspect-w-4 aspect-h-1",
              "label": "t:common.options.letterbox.label"
            }
          ],
          "default": "aspect-w-4 aspect-h-1"
        },
        {
          "type": "link_list",
          "id": "linklist",
          "label": "t:common.settings.linklist.label",
          "info": "t:common.settings.linklist.info"
        }
      ]
    },
    {
      "type": "banner_item",
      "name": "Banner Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Banner Image"
        },
        {
          "type": "number",
          "id": "position",
          "label": "Display Position (Index)",
          "default": 5
        }
      ]
    },
    {
      "type": "background_pattern",
      "name": "t:common.blocks.background_pattern.name",
      "settings": [
        {
          "type": "select",
          "id": "type",
          "label": "t:common.blocks.background_pattern.settings.type.label",
          "options": [
            {
              "value": "diagonal_lines",
              "label": "t:common.options.diagonal_lines.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "grid",
              "label": "t:common.options.grid_lines.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "grid_with_diagonal_lines",
              "label": "t:common.options.grid_with_diagonal_lines.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "crosshatch",
              "label": "t:common.options.crosshatch.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "zig_zag_lines",
              "label": "t:common.options.zig_zag.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "waves_lines",
              "label": "t:common.options.waves.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "dots",
              "label": "t:common.options.dots.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_shapes"
            },
            {
              "value": "triangle",
              "label": "t:common.options.triangles.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_shapes"
            },
            {
              "value": "polka_dot",
